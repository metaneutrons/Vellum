# Vellum Firmware — sdkconfig defaults for E1003
# Target: ESP32-S3

CONFIG_IDF_TARGET="esp32s3"

# Flash / partition
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Panel
CONFIG_VELLUM_PANEL_E1003=y

# NVS
CONFIG_NVS_ENCRYPTION=n

# Wi-Fi
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=y

# Disable esp_hosted (S3 has native WiFi)
CONFIG_ESP_WIFI_REMOTE_ENABLED=n

# GPIO: Do NOT reconfigure pull resistors during sleep (breaks IT8951 BUSY pin)
CONFIG_GPIO_ESP32_SUPPORT_SWITCH_SLP_PULL=n
CONFIG_PM_SLP_IRAM_OPT=n

# HTTP client
# CONFIG_ESP_HTTP_CLIENT_ENABLE_HTTPS is not set

# HTTPD (captive portal)
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Watchdog
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

# LVGL
CONFIG_LV_FONT_MONTSERRAT_18=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_48=y
CONFIG_LV_MEM_CUSTOM=y
CONFIG_LV_MEMCPY_MEMSET_STD=y
CONFIG_LV_MEM_POOL_ALLOC_LARGEST_FREE=y

# Force malloc to prefer PSRAM (LVGL allocations go to PSRAM)
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=256
CONFIG_SPIRAM_USE_MALLOC=y

# PSRAM (8MB on reTerminal E-Series)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# Main task
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
