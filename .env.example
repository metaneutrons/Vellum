# Vellum — Environment Variables
# Copy to .env and fill in all values.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/vellum

# Master encryption key for calendar provider credentials at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Admin API key — minimum 32 characters
ADMIN_API_KEY=change-me-to-a-random-string-at-least-32-chars

# Admin dashboard login credentials
ADMIN_USER=admin
ADMIN_PASS=change-me-at-least-8-chars

# Optional: "development" | "production" | "test" (default: development)
NODE_ENV=development

# Optional: "debug" | "info" | "warn" | "error" (default: info)
LOG_LEVEL=info
